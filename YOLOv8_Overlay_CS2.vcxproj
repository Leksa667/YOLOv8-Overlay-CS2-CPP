  <!-- ═══════════════════════════════════════════════════════════════════
       RELEASE — compile + link settings
       ═══════════════════════════════════════════════════════════════════ -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <SDLCheck>false</SDLCheck>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <ConformanceMode>true</ConformanceMode>
      <PreprocessorDefinitions>NDEBUG;_WINDOWS;UNICODE;_UNICODE;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <!-- Includes : OpenCV + ONNX Runtime (vc17 et vc16 pour compatibilité) -->
      <AdditionalIncludeDirectories>
        $(SolutionDir)src;
        $(SolutionDir)deps\opencv\build\include;
        $(SolutionDir)deps\onnxruntime\include;
        %(AdditionalIncludeDirectories)
      </AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <!-- Libs OpenCV (Release = sans d), ONNX Runtime, Windows -->
      <AdditionalDependencies>
        opencv_world490.lib;
        onnxruntime.lib;
        d3d11.lib;dxgi.lib;
        user32.lib;gdi32.lib;winmm.lib;
        %(AdditionalDependencies)
      </AdditionalDependencies>
      <!-- Chemin libs : vc17 et vc16 (le linker prend ce qui existe) -->
      <AdditionalLibraryDirectories>
        $(SolutionDir)deps\opencv\build\x64\vc17\lib;
        $(SolutionDir)deps\opencv\build\x64\vc16\lib;
        $(SolutionDir)deps\onnxruntime\lib;
        %(AdditionalLibraryDirectories)
      </AdditionalLibraryDirectories>
      <UACExecutionLevel>RequireAdministrator</UACExecutionLevel>
    </Link>
    <!-- ── Post-build : copie les DLLs a cote de l'exe ── -->
    <PostBuildEvent>
      <Command>
        rem OpenCV Release DLL (vc17 ou vc16 selon ce qui est present)
        if exist "$(SolutionDir)deps\opencv\build\x64\vc17\bin\opencv_world490.dll" xcopy /y /i /d "$(SolutionDir)deps\opencv\build\x64\vc17\bin\opencv_world490.dll" "$(OutDir)"
        if exist "$(SolutionDir)deps\opencv\build\x64\vc16\bin\opencv_world490.dll" xcopy /y /i /d "$(SolutionDir)deps\opencv\build\x64\vc16\bin\opencv_world490.dll" "$(OutDir)"
        rem ONNX Runtime DLLs (CUDA GPU build)
        xcopy /y /i /d "$(SolutionDir)deps\onnxruntime\lib\onnxruntime.dll" "$(OutDir)"
        xcopy /y /i /d "$(SolutionDir)deps\onnxruntime\lib\onnxruntime_providers_shared.dll" "$(OutDir)"
        xcopy /y /i /d "$(SolutionDir)deps\onnxruntime\lib\onnxruntime_providers_cuda.dll" "$(OutDir)"
        if exist "$(SolutionDir)deps\onnxruntime\lib\onnxruntime_providers_tensorrt.dll" xcopy /y /i /d "$(SolutionDir)deps\onnxruntime\lib\onnxruntime_providers_tensorrt.dll" "$(OutDir)"
        rem NOTE: CUDA runtime DLLs (cudart, cublas, cudnn...) sont cherches via
        rem AddDllDirectory dans le code -&gt; PyTorch lib. PAS besoin de les copier.
        rem Modele ONNX (optionnel - copie si present a la racine)
        if exist "$(SolutionDir)best.onnx" xcopy /y /i /d "$(SolutionDir)best.onnx" "$(OutDir)"
        exit /b 0
      </Command>
    </PostBuildEvent>
  </ItemDefinitionGroup>
  <!-- ═══════════════════════════════════════════════════════════════════
       DEBUG — compile + link settings
       ═══════════════════════════════════════════════════════════════════ -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>Disabled</Optimization>
      <SDLCheck>false</SDLCheck>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <ConformanceMode>true</ConformanceMode>
      <PreprocessorDefinitions>_DEBUG;_WINDOWS;UNICODE;_UNICODE;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>
        $(SolutionDir)src;
        $(SolutionDir)deps\opencv\build\include;
        $(SolutionDir)deps\onnxruntime\include;
        %(AdditionalIncludeDirectories)
      </AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <!-- Libs OpenCV Debug (opencv_world490d) -->
      <AdditionalDependencies>
        opencv_world490d.lib;
        onnxruntime.lib;
        d3d11.lib;dxgi.lib;
        user32.lib;gdi32.lib;winmm.lib;
        %(AdditionalDependencies)
      </AdditionalDependencies>
      <AdditionalLibraryDirectories>
        $(SolutionDir)deps\opencv\build\x64\vc17\lib;
        $(SolutionDir)deps\opencv\build\x64\vc16\lib;
        $(SolutionDir)deps\onnxruntime\lib;
        %(AdditionalLibraryDirectories)
      </AdditionalLibraryDirectories>
    </Link>
    <PostBuildEvent>
      <Command>
        rem OpenCV Debug DLL
        if exist "$(SolutionDir)deps\opencv\build\x64\vc17\bin\opencv_world490d.dll" xcopy /y /i /d "$(SolutionDir)deps\opencv\build\x64\vc17\bin\opencv_world490d.dll" "$(OutDir)"
        if exist "$(SolutionDir)deps\opencv\build\x64\vc16\bin\opencv_world490d.dll" xcopy /y /i /d "$(SolutionDir)deps\opencv\build\x64\vc16\bin\opencv_world490d.dll" "$(OutDir)"
        rem ONNX Runtime DLLs (DirectML build)
        xcopy /y /i /d "$(SolutionDir)deps\onnxruntime\lib\onnxruntime.dll" "$(OutDir)"
        if exist "$(SolutionDir)deps\onnxruntime\lib\onnxruntime_providers_shared.dll" xcopy /y /i /d "$(SolutionDir)deps\onnxruntime\lib\onnxruntime_providers_shared.dll" "$(OutDir)"
        if not exist "$(OutDir)DirectML.dll" if exist "C:\Windows\System32\DirectML.dll" xcopy /y /d "C:\Windows\System32\DirectML.dll" "$(OutDir)"
        if exist "$(SolutionDir)best.onnx" xcopy /y /i /d "$(SolutionDir)best.onnx" "$(OutDir)"
        exit /b 0
      </Command>
    </PostBuildEvent>
  </ItemDefinitionGroup>
